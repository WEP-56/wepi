{
  "name": "pi-desktop",
  "version": "0.0.1",
  "description": "WEpi desktop workbench for managing Pi RPC agents across project folders.",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "ayuayue",
    "email": "ayuayue@users.noreply.github.com"
  },
  "contributors": [
    {
      "name": "1900EasonJin",
      "url": "https://github.com/1900EasonJin"
    }
  ],
  "homepage": "https://github.com/WEP-56/wepi#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WEP-56/wepi.git"
  },
  "bugs": {
    "url": "https://github.com/WEP-56/wepi/issues"
  },
  "keywords": [
    "pi",
    "coding-agent",
    "electron",
    "desktop",
    "rpc",
    "agent"
  ],
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit && node --max-old-space-size=4096 ./node_modules/electron-vite/bin/electron-vite.js build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis portable zip",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb tar.gz",
    "preview": "electron-vite preview",
    "postinstall": "node scripts/fix-pty-permissions.js",
    "typecheck": "tsc --noEmit",
    "make-icon": "node scripts/make-icon.js"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@monaco-editor/react": "^4.7.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0"
  },
  "build": {
    "appId": "com.wep56.wepi",
    "productName": "WEpi",
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "icon": "build/icon",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "win": {
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Development",
      "maintainer": "ayuayue <ayuayue@users.noreply.github.com>"
    }
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@fiahfy/icns": "^0.0.7",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^38.8.6",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.0",
    "html-to-image": "^1.11.13",
    "katex": "^0.17.0",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.15.0",
    "png-to-ico": "^3.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.0",
    "vite": "^7.3.5",
    "zustand": "^5.0.0"
  }
}
